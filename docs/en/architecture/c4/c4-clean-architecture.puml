@startuml c4-clean-architecture-felix-low-code
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

LAYOUT_WITH_LEGEND()

title Clean Architecture — dependency rule (`apps/web/src`)

Container_Boundary(web, "Web application (clean architecture)") {
    Component(presentation, "Presentation", "React, Emotion, Radix, Tailwind class names", "`presentation/` — UI, controlled views")
    Component(application, "Application", "TypeScript", "`application/` — use-cases, DTOs, orchestration")
    Component(domain, "Domain", "TypeScript", "`domain/` — entities, VOs, domain services, repository interfaces")
    Component(infrastructure, "Infrastructure", "TypeScript", "`infrastructure/` — store, HTTP, persistence implementations")
}

Rel(presentation, application, "Calls use-cases and services")
Rel(application, domain, "Depends on")
Rel(infrastructure, application, "Implements ports")
Rel(infrastructure, domain, "Uses types and interfaces")
Rel(presentation, domain, "May import types only — no infrastructure")

@enduml
