@startuml c4-container-felix-low-code
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

LAYOUT_WITH_LEGEND()

title Container — Felix Low-Code Platform

Person(user, "Designer / developer", "Uses the platform")

System_Boundary(boundary, "Felix Low-Code Platform") {
    Container(web, "Web application", "TypeScript, Next.js 15, React 19 — Emotion + Radix UI + Zustand", "Visual editor, AI generation, template library, data binding, property panel, `apps/web`")
    Container(api, "API service", "Python, FastAPI, Uvicorn, Pydantic", "REST API — `apps/server` (optional)")
    ContainerDb(db, "Primary database", "PostgreSQL (optional)", "Projects, schemas, users")
    ContainerDb(cache, "Cache", "Redis (optional)", "Sessions, hot paths")
}

System_Ext(llm, "LLM APIs", "OpenAI, Claude, DeepSeek, Gemini, Ollama, SiliconFlow …")
System_Ext(sf, "SiliconFlow", "SiliconFlow API — SiliconFlow proxy")
System_Ext(object_store, "Object storage", "Files and export bundles (S3-compatible)")
System_Ext(aws, "AWS services", "S3, Lambda, CloudFront (optional)")

Rel(user, web, "Uses", "HTTPS / WSS")
Rel(web, api, "JSON / REST (when enabled)", "HTTPS")
Rel(api, db, "Reads and writes (optional)", "SQL / TCP")
Rel(api, cache, "Reads and writes (optional)", "TCP")
Rel(api, object_store, "Optional file I/O", "HTTPS")
Rel(web, llm, "AI generation (browser direct)", "HTTPS / local")
Rel(web, sf, "AI generation (SiliconFlow proxy)", "HTTPS")

note right of web
  **Frontend runs standalone — no backend required:**
  - AI connects directly from browser (Ollama localhost or cloud API)
  - Zustand state stored in LocalStorage
  - Template data is local (`presentation/data/templates/`)
end note

@enduml
