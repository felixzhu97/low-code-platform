@startuml c4-context-felix-low-code
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Context.puml

LAYOUT_WITH_LEGEND()

title System Context — Felix Low-Code Platform

Person(designer, "Page designer", "Builds pages with drag-and-drop, optional AI assist")
Person(developer, "Developer", "Exports code, integrates data and APIs")
Person(viewer, "End user", "Views published experiences when deployed")

System(felix, "Felix Low-Code Platform", "Visual builder, schema management, template library, real-time preview, optional AI generation and code export")

System_Ext(llm_cloud, "Cloud LLM APIs", "OpenAI, Anthropic, DeepSeek, Google Gemini, SiliconFlow")
System_Ext(llm_local, "Local LLM (Ollama)", "User's local machine, no public API key required")
System_Ext(auth, "Identity provider", "OAuth2 / OIDC / enterprise SSO")
System_Ext(storage, "Object storage", "Assets, exports, uploads (S3-compatible)")
System_Ext(cdn, "CDN / edge", "Static assets and cached content")
System_Ext(aws, "AWS cloud services", "S3, Lambda, API Gateway, CloudFront (optional)")

Rel(designer, felix, "Edits pages, AI generation", "HTTPS / WSS")
Rel(developer, felix, "Configures projects, exports code", "HTTPS")
Rel(viewer, felix, "Views published content", "HTTPS (when hosted)")
Rel(felix, llm_cloud, "AI generation (cloud)", "HTTPS")
Rel(felix, llm_local, "AI generation (local Ollama)", "Local HTTP")
Rel(felix, auth, "Authenticates users", "HTTPS")
Rel(felix, storage, "Stores and reads files", "HTTPS")
Rel(felix, cdn, "Serves UI assets", "HTTPS")
Rel(felix, aws, "Cloud integration (optional)", "HTTPS")

@enduml
