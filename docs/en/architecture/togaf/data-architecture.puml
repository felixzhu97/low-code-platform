Component "1" *-- "0..*" Component : parent-child
Project "1" *-- "1" Component : root
Project "1" *-- "0..*" DataSource : data sources
Project "1" *-- "1" ThemeConfig : theme
Template "1" *-- "1" Component : root
DataSource "1" *-- "0..*" DataMapping : mapping
Component "1" *-- "0..*" DataMapping : data binding
Component "1" *-- "0..1" DataSource : direct bind
Component "1" *-- "0..1" DataSource : direct bind
Project "1" *-- "1" User : owner
Project "1" *-- "0..*" User : collaborators
HistoryRecord "1" *-- "1" Project : history
PageSchema "1" *-- "1" Project : project base
PageSchema "1" *-- "0..*" Component : has components
PageSchema "1" *-- "0..*" DataSource : has data sources
PageSchema "1" *-- "1" ThemeConfig : has theme
Component "1" *-- "0..1" ChartConfig : chart config
Component "1" *-- "0..*" TableColumn : table columns
Component "1" *-- "0..1" PaginationConfig : pagination
Component "1" *-- "0..*" TreeNode : tree nodes

