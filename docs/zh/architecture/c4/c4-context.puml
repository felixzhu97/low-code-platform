@startuml c4-context-felix-zh
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Context.puml

LAYOUT_WITH_LEGEND()

title 系统上下文 — Felix 低代码平台

Person(designer, "页面设计师", "使用拖拽搭建页面，可选 AI 辅助")
Person(developer, "开发者", "导出代码、对接数据与 API")
Person(viewer, "终端用户", "访问已发布的页面体验")

System(felix, "Felix 低代码平台", "可视化搭建、Schema 管理、模板库、实时预览，可选 AI 生成与代码导出")

System_Ext(llm, "大模型服务", "OpenAI、Anthropic、DeepSeek、Google Gemini、SiliconFlow、Ollama（本地）等")
System_Ext(auth, "身份提供方", "OAuth2 / OIDC / 企业 SSO")
System_Ext(storage, "对象存储", "素材、导出包、上传（S3 兼容）")
System_Ext(cdn, "CDN / 边缘网络", "静态资源与缓存")
System_Ext(aws, "AWS 云服务", "S3、Lambda、API Gateway、CloudFront（可选）")

Rel(designer, felix, "编辑页面、AI 生成", "HTTPS / WSS")
Rel(developer, felix, "配置项目、导出代码", "HTTPS")
Rel(viewer, felix, "访问发布内容", "HTTPS（托管后）")
Rel(felix, llm, "AI 辅助生成（可选）", "HTTPS / 本地")
Rel(felix, auth, "用户认证", "HTTPS")
Rel(felix, storage, "读写文件", "HTTPS")
Rel(felix, cdn, "分发前端资源", "HTTPS")
Rel(felix, aws, "云服务集成（可选）", "HTTPS")

@enduml
