@startuml Technology_Architecture
!theme plain
skinparam linetype ortho

title TOGAF 技术架构 - Felix 低代码平台

package "前端技术栈 (Frontend Technology Stack)" {

  component [Web 浏览器\nWeb Browser] as Browser
  component [React 19\nUI 框架] as React
  component [Next.js 15\n全栈框架] as NextJS
  component [TypeScript\n类型系统] as TypeScript

  component [Emotion\nCSS-in-JS] as Emotion
  component [Radix UI\n无障碍组件库] as RadixUI
  component [React DnD\n拖拽库] as ReactDnD
  component [Recharts\n图表库] as Recharts
  component [Zustand\n状态管理] as Zustand

  component [react-i18next\n国际化库] as ReactI18Next

  component [Monorepo 共享包\npackages/] as SharedPackages
  component [@lowcode-platform/schema\nSchema 类型] as SchemaPkg
  component [@lowcode-platform/component-utils\n组件树工具] as ComponentUtilsPkg
  component [@lowcode-platform/utils\n通用工具] as UtilsPkg

  component [浏览器 Local Storage\n本地存储] as BrowserLocalStorage

  component [AI 生成器内部库\nlib/ai-generator] as AIGeneratorLib
  component [BaseAIClient\n基础客户端] as BaseAIClient
  component [AIClientFactory\n客户端工厂] as AIClientFactoryTech
  component [OllamaClient] as OllamaClientTech
  component [OpenAIClient] as OpenAIClientTech
  component [ClaudeClient] as ClaudeClientTech
  component [DeepSeekClient] as DeepSeekClientTech
  component [GeminiClient] as GeminiClientTech
  component [GroqClient] as GroqClientTech
  component [MistralClient] as MistralClientTech
  component [SiliconFlowClient] as SiliconFlowClientTech
  component [AzureOpenAIClient] as AzureOpenAIClientTech
  component [ComponentGenerator\n组件生成器] as ComponentGeneratorTech
  component [PageGenerator\n页面生成器] as PageGeneratorTech
  component [JSONParser\nJSON 解析器] as JSONParserTech
  component [ComponentPromptBuilder] as ComponentPromptBuilderTech
  component [PagePromptBuilder] as PagePromptBuilderTech
  component [ComponentValidator] as ComponentValidator
  component [PageValidator] as PageValidator

  Browser --> React
  Browser --> NextJS
  Browser --> Emotion
  Browser --> RadixUI
  Browser --> ReactDnD
  Browser --> Recharts
  Browser --> Zustand
  Browser --> ReactI18Next

  SharedPackages --> SchemaPkg
  SharedPackages --> ComponentUtilsPkg
  SharedPackages --> UtilsPkg

  AIGeneratorLib --> BaseAIClient
  BaseAIClient --> OllamaClientTech
  BaseAIClient --> OpenAIClientTech
  BaseAIClient --> ClaudeClientTech
  BaseAIClient --> DeepSeekClientTech
  BaseAIClient --> GeminiClientTech
  BaseAIClient --> GroqClientTech
  BaseAIClient --> MistralClientTech
  BaseAIClient --> SiliconFlowClientTech
  BaseAIClient --> AzureOpenAIClientTech

  AIGeneratorLib --> AIClientFactoryTech
  AIClientFactoryTech --> OllamaClientTech
  AIClientFactoryTech --> OpenAIClientTech
  AIClientFactoryTech --> ClaudeClientTech
  AIClientFactoryTech --> DeepSeekClientTech
  AIClientFactoryTech --> GeminiClientTech
  AIClientFactoryTech --> GroqClientTech
  AIClientFactoryTech --> MistralClientTech
  AIClientFactoryTech --> SiliconFlowClientTech
  AIClientFactoryTech --> AzureOpenAIClientTech

  AIGeneratorLib --> ComponentGeneratorTech
  AIGeneratorLib --> PageGeneratorTech
  AIGeneratorLib --> JSONParserTech
  AIGeneratorLib --> ComponentPromptBuilderTech
  AIGeneratorLib --> PagePromptBuilderTech
  AIGeneratorLib --> ComponentValidator
  AIGeneratorLib --> PageValidator
}

package "后端技术栈 (Backend Technology Stack)" {
  component [FastAPI\nPython Web 框架] as FastAPI
  component [Python 3\n运行时] as PythonRT
  component [Uvicorn\nASGI 服务器] as Uvicorn
  component [Pydantic\n数据校验] as Pydantic

  FastAPI --> Uvicorn
  FastAPI --> Pydantic
}

package "数据存储层 (Data Storage Layer)" {

  component [Local Storage\n浏览器本地存储] as LocalStorage
  component [模板数据\npresentation/data/templates/] as TemplateData
  component [PostgreSQL\n关系型数据库（按部署）] as PostgreSQL
  component [Redis\n缓存（按部署）] as Redis
  component [对象存储\nS3 兼容（按部署）] as ObjectStorage

  PostgreSQL --> Redis
  ObjectStorage --> LocalStorage
}

package "基础设施层 (Infrastructure Layer)" {

  component [云平台\nCloud Platform] as CloudPlatform
  component [负载均衡器] as LoadBalancer
  component [Web 服务器集群] as WebCluster
  component [API 服务器集群\n（按部署）] as APICluster
  component [WebSocket 服务器\n（按部署）] as WSServer
  component [AWS 集成\nS3、Lambda、CloudFront（可选）] as AWSIntegration
  component [CI/CD 流水线] as CICD
  component [Kubernetes\n容器编排（可选）] as K8s
  component [Docker\n容器化] as Docker
}

package "网络与安全 (Network & Security)" {
  component [CDN] as CDN
  component [WAF] as WAF
  component [SSL/TLS] as SSL
  component [API 网关\n（按部署）] as APIGateway
}

package "监控与运维 (Monitoring & Operations)" {
  component [Prometheus\n指标监控（可选）] as Prometheus
  component [Grafana\n可视化（可选）] as Grafana
  component [ELK Stack\n日志分析（可选）] as ELK
  component [Sentry\n错误追踪（可选）] as Sentry
}

' ============ 连接关系 ============

Browser --> CDN : HTTPS
CDN --> WebCluster : 路由
WebCluster --> APIGateway : API 路由（按部署）

Browser --> AIGeneratorLib : AI 生成（浏览器直连）
AIGeneratorLib --> OllamaClientTech : localhost 本地推理
AIGeneratorLib --> OpenAIClientTech : OpenAI API
AIGeneratorLib --> ClaudeClientTech : Anthropic API
AIGeneratorLib --> DeepSeekClientTech : DeepSeek API
AIGeneratorLib --> SiliconFlowClientTech : SiliconFlow API

WebCluster --> PostgreSQL : SQL（按部署）
WebCluster --> Redis : 缓存（按部署）
WebCluster --> ObjectStorage : 文件（按部署）

Browser <--> WSServer : WebSocket（按部署）
WSServer --> Redis : 协作消息（按部署）

note right of Browser
  **前端技术选型：**
  - Next.js 15: SSR/SSG、App Router
  - React 19: UI 运行时
  - TypeScript: 类型安全
  - Emotion: 画布与编辑器 CSS-in-JS
  - Zustand: 组件、画布、主题、UI、历史、自定义组件���态
  - Radix UI: 无障碍交互
  - react-i18next: 国际化
  - Local Storage: 临时数据与项目缓存
  - 模板数据（presentation/data/templates/）: 按类别分文件
end note

note right of AIGeneratorLib
  **AI 生成器内部库结构（lib/ai-generator/）：**
  - AIClientFactory: 根据 provider 创建对应客户端
  - BaseAIClient: fetchWithTimeout、withRetry、parseJSONResponse
  - OllamaClient: 默认 10 分钟超时，支持本地推理
  - ComponentGenerator / PageGenerator: 生成组件或页面
  - JSONParser.flattenPageComponents(): 将嵌套 children 展平为扁平列表
  - ComponentPromptBuilder / PagePromptBuilder: 构建提示词
  - ComponentValidator / PageValidator: 验证生成结果
end note

note right of WebCluster
  **开发模式（无需后端）：**
  - Next.js 独立运行
  - AI 直连浏览器（Ollama localhost 或云 API）
  - Zustand 状态存 Local Storage
  - 模板数据本地加载（presentation/data/templates/）
  - 按部署可启用 FastAPI + PostgreSQL + Redis
end note

@enduml
