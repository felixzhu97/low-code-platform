@startuml Data_Architecture
!theme plain
skinparam linetype ortho

title TOGAF 数据架构 - Felix 低代码平台

package "核心数据实体 (Core Data Entities)" {

  component [Component\n组件实体] as Component
  component [id: string] as CompId
  component [type: string] as CompType
  component [name: string] as CompName
  component [properties: Record<string, any>] as CompProps
  component [position: {x, y, width, height}] as CompPosition
  component [children: string[]] as CompChildren
  component [parentId: string | null] as CompParentId
  component [dataSource: string | null] as CompDataSource
  component [dataMapping: DataMapping[]] as CompDataMapping

  component [Template\n模板实体] as Template
  component [id: string] as TplId
  component [name: string] as TplName
  component [category: string] as TplCategory
  component [tags: string[]] as TplTags
  component [description?: string] as TplDesc
  component [thumbnail: string] as TplThumbnail
  component [rootComponentId: string] as TplRoot
  component [preview: string] as TplPreview
  component [isPublic: boolean] as TplPublic

  component [Project\n项目实体] as Project
  component [id: string] as ProjId
  component [name: string] as ProjName
  component [theme: ThemeConfig] as ProjTheme
  component [ownerId: string] as ProjOwner
  component [collaborators: string[]] as ProjCollaborators
  component [status: string] as ProjStatus

  component [DataSource\n数据源实体] as DataSource
  component [id: string] as DSId
  component [name: string] as DSName
  component [type: 'static' | 'api' | 'database'] as DSType
  component [config: object] as DSConfig
  component [data: any] as DSData
  component [status: string] as DSStatus
  component [errorMessage: string] as DSError
  component [lastUpdated: DateTime] as DSUpdated

  component [DataMapping\n数据映射实体] as DataMappingEntity
  component [id: string] as DMId
  component [componentId: string] as DMCompId
  component [dataSourceId: string] as DMDSId
  component [field: string] as DMField
  component [sourcePath: string] as DMSourcePath
  component [targetPath: string] as DM_targetPath
  component [transform: TransformType] as DMTransform
  component [defaultValue: any] as DMDefault

  component [ThemeConfig\n主题配置实体] as ThemeConfig
  component [primaryColor: string] as TCPrimary
  component [secondaryColor: string] as TCSecondary
  component [backgroundColor: string] as TCBackground
  component [fontFamily: string] as TCFont
  component [isDarkMode: boolean] as TCDark

  component [HistoryRecord\n历史记录实体] as HistoryRecord
  component [id: string] as HRId
  component [projectId: string] as HRProjId
  component [components: Component[]] as HRComponents
  component [timestamp: DateTime] as HRTime
  component [description: string] as HRDesc

  component [PageSchema\n页面Schema] as PageSchema
  component [version: string] as PSVersion
  component [metadata: object] as PSMetadata
  component [components: Component[]] as PSComponents
  component [canvas: object] as PSCanvas
  component [theme: ThemeConfig] as PSTheme
  component [dataSources: DataSource[]] as PSDataSources

  component [ChartConfig\n图表配置] as ChartConfig
}

package "数据存储层 (Data Storage Layer)" {

  component [Local Storage\n浏览器本地存储] as LocalStorage
  component [组件状态缓存] as CompStateCache
  component [项目数据缓存] as ProjectCache
  component [临时数据缓存] as TempDataCache
  component [用户偏好设置] as UserPrefs

  component [PostgreSQL\n关系型数据库（按部署）] as PostgreSQL
  component [projects表] as ProjectsTable
  component [templates表] as TemplatesTable
  component [data_sources表] as DataSourcesTable
  component [users表] as UsersTable

  component [Redis\n缓存（按部署）] as Redis
  component [会话缓存] as SessionCache
  component [协作状态] as CollabState

  component [对象存储\nS3 兼容（按部署）] as ObjectStorage
  component [user_files桶] as UserFiles
  component [exported_code桶] as ExportedCode
}

' ============ 关系 ============

Component "1" o-- "0..*" Component : parentId / children
Project "1" *-- "0..*" Component : 包含
Project "1" *-- "1" ThemeConfig : 主题
DataSource "1" *-- "0..*" DataMappingEntity : 映射
Component "1" *-- "0..*" DataMappingEntity : 数据绑定
Component "1" *-- "0..1" DataSource : 直接绑定
Project "1" *-- "0..*" HistoryRecord : 历史

PageSchema "1" *-- "0..*" Component : 包含（扁平数组）
PageSchema "1" *-- "0..*" DataSource : 包含
PageSchema "1" *-- "1" ThemeConfig : 主题
PageSchema "1" *-- "1" PSCanvas : 画布配置

Template "1" *-- "1" Component : rootComponent（模板根组件）

' ============ 数据流 ============

package "关键数据流 (Key Data Flows)" {

  component [AI生成组件数据流] as AIGenFlow
  component [用户输入描述] as AIUserInput
  component [AI生成嵌套JSON] as AIGenJSON
  component [JSONParser展平嵌套children] as AIFlatten
  component [ApplyTemplateUseCase应用] as AIApply
  component [Zustand状态更新] as AIStoreUpdate
  component [画布渲染] as AIRender

  component [数据绑定数据流] as DBFlow
  component [创建DataSource] as DBCreate
  component [绑定到Component] as DBBind
  component [DataBindingService获取数据] as DBService
  component [实时渲染更新] as DBRender

  component [Schema导入数据流] as SchemaImportFlow
  component [上传Schema JSON] as SchemaUpload
  component [JSONParser解析] as SchemaParse
  component [扁平嵌套children] as SchemaFlatten
  component [渲染到画布] as SchemaRender

  component [模板应用数据流] as TemplateApplyFlow
  component [浏览模板库] as TplBrowse
  component [选择模板] as TplSelect
  component [ApplyTemplateUseCase执行] as TplApply
  component [ComponentFactory创建组件] as TplCreate
  component [状态更新] as TplUpdate

  AIGenFlow --> AIUserInput
  AIGenFlow --> AIGenJSON
  AIGenFlow --> AIFlatten
  AIFlatten ..> "JSONParser\n.flattenPageComponents()" as JSONParserNote : 调用
  AIGenFlow --> AIApply
  AIApply --> AIStoreUpdate
  AIStoreUpdate --> AIRender

  DBFlow --> DBCreate
  DBFlow --> DBBind
  DBFlow --> DBService
  DBFlow --> DBRender

  SchemaImportFlow --> SchemaUpload
  SchemaImportFlow --> SchemaParse
  SchemaParse --> SchemaFlatten
  SchemaFlatten ..> "JSONParser\n.flattenPageComponents()" as JSONParserNote2 : 调用
  SchemaImportFlow --> SchemaRender

  TemplateApplyFlow --> TplBrowse
  TemplateApplyFlow --> TplSelect
  TemplateApplyFlow --> TplApply
  TplApply --> TplCreate
  TplCreate --> TplUpdate
}

' ============ 数据访问 ============

Component ..> LocalStorage : 临时缓存
Project ..> LocalStorage : 临时缓存
UserPrefs ..> LocalStorage : 偏好
Template ..> LocalStorage : 模板数据（presentation/data/templates/）

Component ..> PostgreSQL : 持久化（按部署）
Project ..> PostgreSQL : 持久化（按部署）
Template ..> PostgreSQL : 持久化（按部署）

Project ..> Redis : 会话（按部署）
CollabState ..> Redis : 协作（按部署）

Project ..> ObjectStorage : 文件存储（按部署）

note right of Component
  **关键设计：扁平 components 数组 + parentId**
  AI 生成的嵌套 children（完整对象）在 JSONParser.flattenPageComponents()
  中被展平为 parentId 关联的扁平列表，确保 Zustand stores 正确渲染。
end note

note right of AIGenFlow
  **AI 生成数据流：**
  1. 用户自然语言输入
  2. AI 返回嵌套 JSON（children 含完整对象）
  3. JSONParser.flattenPageComponents() 展平为扁平列表
  4. ApplyTemplateUseCase 应用到 Zustand stores
  5. 画布正确渲染完整组件树
end note

note right of TemplateApplyFlow
  **模板应用数据流（appendTemplateFromComponents）：**
  1. 用户浏览 TemplateGallery，选择模板
  2. ApplyTemplateUseCase 调用 TemplateService.getTemplateById()
  3. ComponentFactory.createComponent() 创建所有组件（带 parentId）
  4. ComponentStore.addComponents() 批量添加
  5. 画布渲染完整组件树
end note

@enduml
