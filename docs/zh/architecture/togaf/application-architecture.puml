@startuml Application_Architecture
!theme plain
skinparam linetype ortho

title TOGAF 应用架构 - Felix 低代码平台

package "Felix 低代码平台应用系统" {

  package "表现层 (Presentation Layer)" {

    component [可视化编辑器] as VisualEditor
    component [组件面板] as ComponentPanel
    component [属性面板] as PropertyPanel
    component [模板库] as TemplateLibrary
    component [数据面板] as DataPanel
    component [数据源选择器] as DataSourceSelector
    component [JSON数据输入] as JsonDataInput

    component [组件渲染器] as ComponentRenderers
    component [基础组件渲染器\nBasicRenderer] as BasicRenderer
    component [图表组件渲染器\nChartRenderer] as ChartRenderer
    component [数据组件渲染器\nDataRenderer] as DataRenderer
    component [表单组件渲染器\nFormRenderer] as FormRenderer
    component [布局组件渲染器\nLayoutRenderer] as LayoutRenderer

    component [AI对话组件\nAIChat] as AIChat
    component [AI生成器UI\nAIGenerator] as AIGeneratorUI
    component [表单构建器\nFormBuilder] as FormBuilder
    component [主题编辑器\nThemeEditor] as ThemeEditor
    component [动画编辑器\nAnimationEditor] as AnimationEditor

    ComponentRenderers --> BasicRenderer
    ComponentRenderers --> ChartRenderer
    ComponentRenderers --> DataRenderer
    ComponentRenderers --> FormRenderer
    ComponentRenderers --> LayoutRenderer
  }

  package "应用层 (Application Layer)" {

    component [组件管理服务\nComponentManagementService] as ComponentService
    component [模板管理服务\nTemplateManagementService] as TemplateService
    component [数据绑定服务\nDataBindingService] as DataBindingService
    component [数据源服务\nDataSourceService] as DataSourceService
    component [JSON工具服务\nJsonHelperService] as JsonHelperService
    component [画布管理服务\nCanvasManagementService] as CanvasService
    component [历史记录服务\nHistoryService] as HistoryService
    component [Schema管理服务\nSchemaManagementService] as SchemaService
    component [AI生成器适配器\nAIGeneratorAdapter] as AIGeneratorAdapter
    component [应用模板用例\nApplyTemplateUseCase] as ApplyTemplateUseCase
  }

  package "领域层 (Domain Layer)" {
    component [Component 组件实体] as ComponentEntity
    component [Template 模板实体] as TemplateEntity
    component [Project 项目实体] as ProjectEntity
    component [DataSource 数据源实体] as DataSourceEntity
    component [DataMapping 数据映射实体] as DataMappingEntity
    component [PageSchema 页面Schema实体] as PageSchemaEntity
    component [ComponentFactory 组件工厂] as ComponentFactory
  }

  package "基础设施层 (Infrastructure Layer)" {

    component [状态管理\nState Management] as StateManagement
    component [画布状态\nCanvasStore] as CanvasStore
    component [组件状态\nComponentStore] as ComponentStore
    component [数据状态\nDataStore] as DataStore
    component [历史状态\nHistoryStore] as HistoryStore
    component [主题状态\nThemeStore] as ThemeStore
    component [UI状态\nUIStore] as UIStore

    component [持久化管理器\nPersistenceManager] as PersistenceManager
    component [本地存储适配器\nLocalStorageAdapter] as LocalStorageAdapter
    component [持久化管理器\nPersistenceManager] as DBAdapter

    component [Schema导出服务\nSchemaExportService] as SchemaExportService
    component [Schema导入服务\nSchemaImportService] as SchemaImportService
    component [Schema渲染器\nSchemaRenderer] as SchemaRenderer

    component [AI生成器内部库\napps/web/src/lib/ai-generator] as AIGeneratorLib
    component [AI客户端工厂\nAIClientFactory] as AIClientFactory
    component [OpenAI客户端] as OpenAIClient
    component [Claude客户端] as ClaudeClient
    component [DeepSeek客户端] as DeepSeekClient
    component [Gemini客户端] as GeminiClient
    component [Ollama客户端] as OllamaClient
    component [Groq客户端] as GroqClient
    component [Mistral客户端] as MistralClient
    component [SiliconFlow客户端] as SiliconFlowClient
    component [AzureOpenAI客户端] as AzureOpenAIClient
    component [组件生成器\nComponentGenerator] as ComponentGenerator
    component [页面生成器\nPageGenerator] as PageGenerator
    component [组件验证器\nComponentValidator] as ComponentValidator
    component [页面验证器\nPageValidator] as PageValidator
    component [JSON解析器\nJSONParser] as JsonParser
    component [组件提示构建器\nComponentPromptBuilder] as ComponentPromptBuilder
    component [页面提示构建器\nPagePromptBuilder] as PagePromptBuilder

    StateManagement --> CanvasStore
    StateManagement --> ComponentStore
    StateManagement --> DataStore
    StateManagement --> HistoryStore
    StateManagement --> ThemeStore
    StateManagement --> UIStore

    PersistenceManager --> LocalStorageAdapter
    PersistenceManager --> DBAdapter

    AIGeneratorLib --> AIClientFactory
    AIClientFactory --> OpenAIClient
    AIClientFactory --> ClaudeClient
    AIClientFactory --> DeepSeekClient
    AIClientFactory --> GeminiClient
    AIClientFactory --> OllamaClient
    AIClientFactory --> GroqClient
    AIClientFactory --> MistralClient
    AIClientFactory --> SiliconFlowClient
    AIClientFactory --> AzureOpenAIClient
    AIGeneratorLib --> ComponentGenerator
    AIGeneratorLib --> PageGenerator
    AIGeneratorLib --> ComponentValidator
    AIGeneratorLib --> PageValidator
    AIGeneratorLib --> JsonParser
    AIGeneratorLib --> ComponentPromptBuilder
    AIGeneratorLib --> PagePromptBuilder
  }
}

package "外部系统 (External Systems)" {
  component [AI API\nOpenAI / Claude / DeepSeek / Gemini] as AIServices
  component [Ollama\n本地大模型] as OllamaLocal
  component [SiliconFlow API] as SiliconFlowAPI
  component [认证服务\nAuth Service] as AuthService
  component [数据库\nDatabase] as Database
  component [缓存服务\nCache] as CacheService
  component [对象存储\nObject Storage] as ObjectStorage
}

' ========== 交互关系 ==========

VisualEditor --> ComponentService : 调用
VisualEditor --> CanvasService : 调用
VisualEditor --> HistoryService : 调用
ComponentPanel --> ComponentService : 调用
PropertyPanel --> ComponentService : 调用
PropertyPanel --> DataBindingService : 调用
TemplateLibrary --> TemplateService : 调用
DataPanel --> DataBindingService : 调用
DataPanel --> DataSourceService : 调用
DataSourceSelector --> DataSourceService : 调用
JsonDataInput --> JsonHelperService : 调用
AIGeneratorUI --> AIGeneratorAdapter : 调用
AIGeneratorAdapter --> AIGeneratorLib : 调用
AIGeneratorAdapter --> ApplyTemplateUseCase : 应用生成结果
AIChat --> AIGeneratorAdapter : 对话调用
FormBuilder --> ApplyTemplateUseCase : 应用表单
VisualEditor --> ComponentRenderers : 使用
ComponentRenderers --> ComponentService : 调用

ComponentService --> ComponentEntity : 使用
TemplateService --> TemplateEntity : 使用
ApplyTemplateUseCase --> TemplateService : 调用
DataBindingService --> DataSourceEntity : 使用
DataSourceService --> DataSourceEntity : 使用
CanvasService --> ComponentFactory : 使用
SchemaExportService --> PageSchemaEntity : 使用
SchemaImportService --> PageSchemaEntity : 使用
SchemaRenderer --> PageSchemaEntity : 使用

AIGeneratorLib --> ComponentGenerator : 使用
AIGeneratorLib --> PageGenerator : 使用
ComponentGenerator --> AIClientFactory : 调用
PageGenerator --> AIClientFactory : 调用
JsonParser --> ComponentGenerator : 解析嵌套组件

AIGeneratorLib --> OllamaClient : 本地推理
AIGeneratorLib --> OpenAIClient : 云服务
AIGeneratorLib --> SiliconFlowAPI : SiliconFlow

ComponentStore --> PersistenceManager : 持久化
ComponentService --> StateManagement : 更新状态

note right of AIGeneratorAdapter
  **AI 生成关键流程：**
  1. 用户自然语言输入 → AIChat / AIGeneratorUI
  2. AIGeneratorAdapter → AIGeneratorLib
  3. AIClientFactory 选择客户端（Ollama/OpenAI/Claude 等）
  4. ComponentGenerator / PageGenerator 生成
  5. JSONParser.flattenPageComponents() 将嵌套 children 展平为扁平列表
  6. ApplyTemplateUseCase 应用到 Zustand stores → 画布渲染
end note

note right of ComponentRenderers
  **组件渲染分工：**
  - BasicRenderer: text, button, image, divider, avatar, badge, tag, progress, carousel
  - LayoutRenderer: container, grid-layout, flex-layout, card, collapse, tabs, modal, drawer
  - FormRenderer: input, textarea, select, checkbox, radio, switch, slider, date-picker, form
  - ChartRenderer: 各种图表类型
  - DataRenderer: data-* 类型组件
end note

@enduml
